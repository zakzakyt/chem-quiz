<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <title>有機化学アキネイター - 68種類の化合物を特定せよ！</title>

    <link rel="manifest" href="/manifest.json">
    <meta name="theme-color" content="#34495e">
    <link rel="apple-touch-icon" href="/images/icon-192.png">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">

    <meta name="description" content="大学入試・プロレベルの有機化合物を特定する「有機化学アキネイター」。全68種類のデータセットから、いかに少ない質問で構造を決定できるか挑戦しましょう。">
    <meta name="keywords" content="有機化学, 構造決定, 化学, クイズ, 大学入試, 共通テスト, 学習アプリ, 九工大, アキネイター">
    
    <meta name="google-site-verification" content="sgJmgQeuXZ41wG74J3_lR81T8bAys4hFCBpR_S4-K2M" />

    <meta property="og:title" content="有機化学アキネイター">
    <meta property="og:description" content="君は最短で全68種類の化合物を特定できるか？">
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://chem-quiz.onrender.com">
    <meta property="og:image" content="https://chem-quiz.onrender.com/images/benzene.png">
    <meta name="twitter:card" content="summary_large_image">

    <style>
        :root {
            --primary-color: #4a90e2;
            --bg-color: #f4f7f6;
            --text-color: #333;
            --success-color: #27ae60;
            --warning-color: #e67e22;
        }
        body {
            font-family: 'Helvetica Neue', Arial, 'Hiragino Kaku Gothic ProN', 'Meiryo', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-color);
            padding: 20px;
            display: flex;
            justify-content: center;
        }
        .container { max-width: 600px; width: 100%; display: flex; flex-direction: column; gap: 20px; }
        
        .header-info { text-align: center; margin-bottom: 10px; }
        .turn-badge {
            background: #2c3e50;
            color: white;
            padding: 5px 15px;
            border-radius: 20px;
            font-weight: bold;
            display: inline-block;
        }

        .card {
            background: white;
            border-radius: 12px;
            padding: 20px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        }
        .card h3 {
            margin-top: 0;
            color: var(--primary-color);
            border-bottom: 2px solid #eee;
            padding-bottom: 8px;
        }

        .control-group { margin-bottom: 15px; display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
        select, input { padding: 10px; border: 1px solid #ddd; border-radius: 6px; font-size: 1rem; }
        
        button { border: none; padding: 12px 20px; border-radius: 6px; color: white; cursor: pointer; font-weight: bold; width: 100%; transition: opacity 0.2s; font-size: 1rem; }
        button:hover { opacity: 0.9; }
        
        /* --- ローディング（無効化）時のボタンスタイル --- */
        button:disabled {
            background-color: #bdc3c7 !important; /* グレーにする */
            cursor: not-allowed;
            opacity: 0.8;
            transform: none;
        }

        .btn-ask { background-color: var(--primary-color); }
        .btn-guess { background-color: var(--warning-color); }
        .btn-giveup { background-color: #95a5a6; margin-top: 10px; font-size: 0.9rem; }
        .btn-start { background-color: var(--success-color); font-size: 1.2rem; padding: 15px; }

        .hidden { display: none !important; }

        /* モーダル/オーバーレイ */
        #overlay-screen {
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.85);
            display: flex; justify-content: center; align-items: center; z-index: 1000;
        }
        .modal-box {
            background: white; padding: 30px; border-radius: 15px; text-align: center;
            max-width: 90%; width: 450px; box-shadow: 0 10px 25px rgba(0,0,0,0.2);
        }

        .rank-text { font-size: 2.5rem; color: var(--warning-color); margin: 10px 0; font-weight: bold; }
        
        #logs { display: flex; flex-direction: column; gap: 10px; padding-bottom: 50px; }
        .log-item { 
            padding: 12px; 
            border-radius: 8px; 
            background: white; 
            border-left: 5px solid #ccc; 
            display: flex; 
            justify-content: space-between; 
            box-shadow: 0 2px 5px rgba(0,0,0,0.03); 
            /* ★ここを追加（0.3秒かけてフワッと現れる） */
            animation: slideFadeIn 0.3s ease-out forwards; 
        }
        .log-item.yes { border-left-color: var(--success-color); background: #eafaf1; }
        .log-item.no { border-left-color: #e74c3c; background: #fdedec; }
        .log-item.giveup { border-left-color: #95a5a6; background: #f4f4f4; color: #7f8c8d; }

        /* シェアボタン */
        .btn-x-share {
            background-color: #000; color: #fff; display: flex; align-items: center;
            justify-content: center; gap: 8px; margin: 15px 0;
        }

        /* --- ここから予測変換リストのスタイル --- */
        .autocomplete-wrapper { position: relative; width: 100%; }
        .autocomplete-items {
            position: absolute; border: 1px solid #ddd; border-top: none; z-index: 99;
            top: 100%; left: 0; right: 0; max-height: 200px; overflow-y: auto;
            background-color: #fff; border-radius: 0 0 6px 6px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .autocomplete-items div { padding: 12px; cursor: pointer; border-bottom: 1px solid #eee; }
        .autocomplete-items div:hover { background-color: #f0f0f0; color: var(--primary-color); font-weight: bold;}

        /* --- ログ追加時のアニメーション定義 --- */
        @keyframes slideFadeIn {
            0% { opacity: 0; transform: translateY(-15px); }
            100% { opacity: 1; transform: translateY(0); }
        }

        /* --- 図鑑機能のスタイル --- */
        .btn-zukan { background-color: #8e44ad; margin-top: 15px; }
        .zukan-grid {
            display: grid; grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
            gap: 10px; margin-top: 15px; max-height: 60vh; overflow-y: auto; padding-right: 5px;
        }
        .zukan-item {
            border: 2px solid #ddd; border-radius: 8px; padding: 10px; text-align: center; background: #fff;
            transition: transform 0.2s;
        }
        .zukan-item.locked { background: #eee; color: #999; border-color: #eee; }
        .zukan-item.locked img { filter: brightness(0) invert(0.8); /* シルエット風にする */ }
        .zukan-item img { width: 100%; height: 70px; object-fit: contain; margin-bottom: 5px; }
        .zukan-item .name { font-size: 0.85rem; font-weight: bold; margin-bottom: 3px; }
        .zukan-item .formula { font-size: 0.75rem; color: #555; }
        .zukan-item .best-rank { font-size: 0.8rem; font-weight: bold; margin-top: 5px; color: var(--warning-color); }

    </style>
</head>
<body>

<div id="overlay-screen">
    <div id="start-content" class="modal-box">
        <h1>有機化学アキネイター</h1>
        <p>全68種類の有機化合物から<br>正解を特定してください</p>
        <button class="btn-start" onclick="startGame()">🚀 ゲームスタート</button>
        <button class="btn-zukan" onclick="openZukan('start-content')">📖 コンプリート図鑑 (<span id="start-zukan-count">0</span>/68)</button>
    </div> 

    <div id="zukan-content" class="modal-box" style="display:none; max-width: 800px; width: 95%;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
            <h2 style="margin:0;">📖 有機化学図鑑</h2>
            <button onclick="closeZukan()" style="width: auto; background: #e74c3c; padding: 8px 15px;">✖ 閉じる</button>
        </div>
        <p style="text-align: left; margin: 0; font-weight: bold;">収集率: <span id="zukan-progress">0</span> / 68 種類</p>
        <div id="zukan-grid" class="zukan-grid"></div>
    </div>

    <div style="text-align: center; margin-top: 20px;">
        <a href="ここにコピーしたGoogleフォームのURLを貼り付ける" target="_blank" rel="noopener noreferrer" style="color: #7f8c8d; font-size: 14px; text-decoration: underline;">
            💡 バグ報告・追加してほしい機能のリクエストはこちら
        </a>
    </div>

    <div id="result-content" class="modal-box" style="display:none;">
        <h2 id="result-title">🎉 CONGRATULATIONS!</h2>
        <p>正解は <b id="result-name" style="font-size:1.4em;"></b> でした。</p>
        <p id="result-formula" style="font-size: 1.5em; font-family: serif; color: #555;"></p>
        
        <div style="margin: 15px 0;">
            <img id="result-image" src="" alt="構造式" style="display:none; max-width: 100%; max-height: 200px; border: 1px solid #ddd; border-radius: 8px; padding: 5px;">
        </div>

        <div class="rank-text" id="result-rank"></div>
        <p>記録: <b id="result-turns"></b> ターン</p>

        <button id="share-button" class="btn-x-share">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.045 4.126H5.078z"></path></svg>
            結果をXでシェアする
        </button>
        
        <button class="btn-start" style="margin:0;" onclick="startGame()">🔄 もう一度遊ぶ</button>

        <button class="btn-zukan" onclick="openZukan('result-content')" style="width: 100%; margin-top: 10px; padding: 12px; font-weight: bold; color: white; border: none; border-radius: 6px; cursor: pointer;">📖 コンプリート図鑑 (<span id="result-zukan-count">0</span>/68)</button>
    </div>
</div>

<div class="container">
    <header class="header-info">
        <h1>有機化学アキネイター</h1>
        <div style="display: flex; gap: 10px; justify-content: center;">
            <div class="turn-badge">現在: <span id="turn-display">0</span> ターン目</div>
            <div class="turn-badge" style="background: #e67e22;">候補: <span id="candidate-count">68</span> / 68</div>
        </div>
    </header>

    <div class="card">
        <h3>🔍 質問する</h3>
        <div class="control-group">
            <select id="target" style="flex:2;" onchange="updateFormUI()">
                <optgroup label="原子の数">
                    <option value="C">炭素原子 (C)</option>
                    <option value="H">水素原子 (H)</option>
                    <option value="O">酸素原子 (O)</option>
                    <option value="N">窒素原子 (N)</option>
                    <option value="S">硫黄原子 (S)</option>
                    <option value="Cl">塩素原子 (Cl)</option>
                </optgroup>
                <optgroup label="結合・構造">
                    <option value="double_bond">炭素間二重結合 (C=C)</option>
                    <option value="triple_bond">三重結合 (C≡C)</option>
                    <option value="ring_benzene">ベンゼン環</option>
                    <option value="is_chiral" data-type="bool">不斉炭素原子</option>
                </optgroup>
                <optgroup label="官能基">
                    <option value="group_oh">ヒドロキシ基 (-OH)</option>
                    <option value="group_cooh">カルボキシ基 (-COOH)</option>
                    <option value="group_cho">アルデヒド基 (-CHO)</option>
                    <option value="group_co">ケトン基 (-CO-)</option>
                    <option value="group_ether">エーテル結合 (-O-)</option>
                    <option value="group_ester">エステル結合 (-COO-)</option>
                    <option value="group_nh2">アミノ基 (-NH₂)</option>
                    <option value="group_so3h">スルホ基 (-SO₃H)</option>
                    <option value="group_amide">アミド基 (-NHCO-)</option>
                    <option value="group_nitro">ニトロ基 (-NO₂)</option>
                </optgroup>
                <optgroup label="反応・性質">
                    <option value="reaction_acid" data-type="bool">酸性を示す</option>
                    <option value="reaction_silver" data-type="bool">銀鏡反応を示す</option>
                    <option value="reaction_iodoform" data-type="bool">ヨードホルム反応を示す</option>
                    <option value="reaction_fe" data-type="bool">塩化鉄(III)で呈色する</option>
                    <option value="reaction_sodium" data-type="bool">Naと反応してH₂発生</option>
                    <option value="reaction_bromine" data-type="bool">臭素水を脱色する</option>
                    <option value="reaction_dehydrate" data-type="bool">加熱で分子内脱水する</option>
                </optgroup>
            </select>
        </div>

        <div id="numeric-input-area" class="control-group">
            <span>の数が</span>
            <input type="number" id="value" value="1" min="0" style="flex:1;" onkeydown="if(event.key==='Enter') askQuestion()">
            <select id="operator" style="flex:1;">
                <option value="equal">と同じ</option>
                <option value="gte">以上 (≧)</option>
                <option value="lte">以下 (≦)</option>
            </select>
            <span>ですか？</span>
        </div>

        <div id="boolean-text-area" class="control-group hidden">
            <span style="font-weight: bold; color: #555;">を示しますか？</span>
        </div>

        <button id="btn-ask" class="btn-ask" onclick="askQuestion()">質問を送信</button>
    </div>

    <div class="card">
        <h3>💡 名前を答える</h3>
        <div class="control-group">
            <div class="autocomplete-wrapper">
                <input type="text" id="guessName" placeholder="化合物名を入力 (例: ベンゼン)" style="width: 100%; box-sizing: border-box;" autocomplete="off" onkeydown="if(event.key==='Enter') guessAnswer()">
                <div id="autocomplete-list" class="autocomplete-items"></div>
            </div>
        </div>
        <button id="btn-guess" class="btn-guess" onclick="guessAnswer()">回答する</button>
        <button id="btn-giveup" class="btn-giveup" onclick="giveUp()">降参して答えを見る...</button>
    </div>

    <div id="logs"></div>
</div>

<script>
    // --- PWA Service Worker の登録 ---
    if ('serviceWorker' in navigator) {
        window.addEventListener('load', () => {
            navigator.serviceWorker.register('/sw.js')
                .then(reg => console.log('Service Worker 登録成功!', reg))
                .catch(err => console.log('Service Worker 登録失敗...', err));
        });
    }

    // --- 🔊 効果音の準備 ---
    const seYes = new Audio('/sounds/yes.mp3');
    const seNo = new Audio('/sounds/no.mp3');
    const seCorrect = new Audio('/sounds/correct.mp3');
    const seCorrectS = new Audio('/sounds/correct_s.mp3'); // ★ここを追加！(Sランク用)
    const seWrong = new Audio('/sounds/wrong.mp3');
    const seGiveup = new Audio('/sounds/giveup.mp3');

    // 音量を少し下げておく（0.0 〜 1.0）
    seYes.volume = 0.5;
    seNo.volume = 0.5;
    seCorrect.volume = 0.5;
    seCorrectS.volume = 0.5; // ★ここを追加！
    seWrong.volume = 0.5;
    seGiveup.volume = 0.5;

    let compoundNames = [];

    // ★ targetId の代わりに token を記憶する
    let gameState = {
        token: null, 
        turnCount: 0,
        history: []
    };

    window.onload = async () => {
        updateFormUI();
        const res = await fetch('/api/compounds/names');
        compoundNames = await res.json();
        setupAutocomplete();
        updateZukanCount(); // ★これを追加
    };

    function hiraToKata(str) {
        return str.replace(/[\u3041-\u3096]/g, match => String.fromCharCode(match.charCodeAt(0) + 0x60));
    }

    function setupAutocomplete() {
        const inp = document.getElementById("guessName");
        const listContainer = document.getElementById("autocomplete-list");

        inp.addEventListener("input", function() {
            const val = this.value;
            listContainer.innerHTML = ""; 
            if (!val) return;

            const normalizedVal = hiraToKata(val); 

            compoundNames.forEach(name => {
                if (name.includes(normalizedVal) || name.includes(val)) {
                    const div = document.createElement("div");
                    div.innerText = name;
                    div.addEventListener("click", function() {
                        inp.value = name; 
                        listContainer.innerHTML = ""; 
                    });
                    listContainer.appendChild(div);
                }
            });
        });

        document.addEventListener("click", function (e) {
            if (e.target !== inp) listContainer.innerHTML = "";
        });
    }

    function updateFormUI() {
        const targetSelect = document.getElementById('target');
        const selectedOption = targetSelect.options[targetSelect.selectedIndex];
        const isBoolean = selectedOption.getAttribute('data-type') === 'bool' 
                          || selectedOption.parentElement.label === '反応・性質';
        
        document.getElementById('numeric-input-area').classList.toggle('hidden', isBoolean);
        document.getElementById('boolean-text-area').classList.toggle('hidden', !isBoolean);
    }

    async function startGame() {
        const response = await fetch('/api/reset', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({}) });
        const data = await response.json();
        
        // ★ サーバーから送られてきた暗号化チケット（token）を記憶
        gameState = { token: data.token, turnCount: 0, history: [] };
        
        document.getElementById('logs').innerHTML = '';
        document.getElementById('guessName').value = '';
        document.getElementById('candidate-count').innerText = data.totalCandidates;
        updateTurn(0);
        document.getElementById('overlay-screen').style.display = 'none';
        document.getElementById('result-content').style.display = 'none';
        window.scrollTo(0,0);
    }

    // --- 1. 質問する関数 ---
    async function askQuestion() {
        const btn = document.getElementById('btn-ask');
        const originalText = btn.innerText;
        btn.innerText = '⏳ 判定中...';
        btn.disabled = true;

        const targetSelect = document.getElementById('target');
        const selectedOption = targetSelect.options[targetSelect.selectedIndex];
        const target = targetSelect.value;
        const isBoolean = !document.getElementById('boolean-text-area').classList.contains('hidden');
        let value = isBoolean ? 1 : document.getElementById('value').value;
        let operator = isBoolean ? 'equal' : document.getElementById('operator').value;

        try {
            gameState.turnCount++;
            // ★ tokenを送信
            const response = await fetch('/api/ask', {
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ token: gameState.token, history: gameState.history, target, value, operator })
            });

            const data = await response.json();
            gameState.history.push(data.newHistoryItem);
            updateTurn(gameState.turnCount);
            
            const countEl = document.getElementById('candidate-count');
            countEl.innerText = data.remainingCount;
            countEl.parentElement.style.transform = "scale(1.2)";
            setTimeout(() => countEl.parentElement.style.transform = "scale(1)", 200);

            const isYes = data.answer === "はい";
            if (isYes) { seYes.currentTime = 0; seYes.play(); } else { seNo.currentTime = 0; seNo.play(); }

            const qText = isBoolean ? `Q. ${selectedOption.text} を示しますか？` : `Q. ${selectedOption.text} は ${value} ${getOpText(operator)} ですか？`;
            addLog(qText, `A. ${data.answer} ${isYes ? '⭕' : '❌'} (残り${data.remainingCount}件)`, isYes ? "yes" : "no");
        } finally { 
            btn.innerText = originalText; btn.disabled = false;
        }
    }

    // --- 2. 回答する関数 ---
    async function guessAnswer() {
        const name = document.getElementById('guessName').value;
        if(!name) return;

        const btn = document.getElementById('btn-guess');
        const originalText = btn.innerText;
        btn.innerText = '⏳ 判定中...';
        btn.disabled = true;

        try {
            gameState.turnCount++;
            // ★ tokenを送信
            const response = await fetch('/api/guess', { 
                method: 'POST', headers: { 'Content-Type': 'application/json' }, 
                body: JSON.stringify({ token: gameState.token, history: gameState.history, name }) 
            });
            const data = await response.json();
            
            if (data.correct) {
                saveToZukan(data.id, gameState.turnCount);
                updateZukanCount(); 
                if (gameState.turnCount <= 5) { seCorrectS.currentTime = 0; seCorrectS.play(); } else { seCorrect.currentTime = 0; seCorrect.play(); }
                showResult(name, gameState.turnCount, data.image, data.formula, false);
            } else {
                seWrong.currentTime = 0; seWrong.play();
                if (data.newHistoryItem) gameState.history.push(data.newHistoryItem);
                updateTurn(gameState.turnCount); 
                
                const countEl = document.getElementById('candidate-count');
                countEl.innerText = data.remainingCount;
                countEl.parentElement.style.transform = "scale(1.2)";
                setTimeout(() => countEl.parentElement.style.transform = "scale(1)", 200);

                alert("違います..."); 
                addLog(`回答: ${name}`, `不正解... 💨 (残り${data.remainingCount}件)`, "no"); 
            }
        } finally { 
            btn.innerText = originalText; btn.disabled = false;
        }
    }

    // --- 3. 降参する関数 ---
    async function giveUp() {
        if(!confirm("本当に降参しますか？")) return;
        const btn = document.getElementById('btn-giveup');
        const originalText = btn.innerText;
        btn.innerText = '⏳ 処理中...';
        btn.disabled = true;

        try {
            seGiveup.currentTime = 0; seGiveup.play();
            // ★ tokenを送信
            const response = await fetch('/api/giveup', { 
                method: 'POST', headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ token: gameState.token }) 
            });
            const data = await response.json();
            showResult(data.name, gameState.turnCount, data.image, data.formula, true);
        } finally { 
            btn.innerText = originalText; btn.disabled = false;
        }
    }

    function showResult(name, turns, imageFile, formula, isGiveUp) {
        document.getElementById('result-name').innerText = name;
        document.getElementById('result-turns').innerText = turns;
        document.getElementById('result-formula').innerHTML = formula ? formula.replace(/(\d+)/g, "<sub>$1</sub>") : "";
        
        const img = document.getElementById('result-image');
        if (imageFile) { img.src = "/images/" + imageFile; img.style.display = "inline-block"; }
        else { img.style.display = "none"; }

        const title = document.getElementById('result-title');
        const rankEl = document.getElementById('result-rank');
        const shareBtn = document.getElementById('share-button');

        if (isGiveUp) {
            title.innerText = "😵 GIVE UP..."; title.style.color = "#7f8c8d"; rankEl.innerText = ""; shareBtn.style.display = 'none';
        } else {
            title.innerText = "🎉 CONGRATULATIONS!"; title.style.color = "#27ae60";
            let rank = turns <= 5 ? "S (神業)" : turns <= 8 ? "A (優秀)" : turns <= 12 ? "B (普通)" : "C";
            rankEl.innerText = rank;
            shareBtn.style.display = 'flex';
            shareBtn.onclick = () => {
                const text = `【有機化学アキネイター】\n正解の「${name}」を ${turns} ターンで特定しました！\nランク: ${rank}\n#有機化学クイズ #九工大`;
                window.open(`https://twitter.com/intent/tweet?text=${encodeURIComponent(text)}&url=${encodeURIComponent(window.location.href)}`, '_blank');
            };
        }
        document.getElementById('overlay-screen').style.display = 'flex';
        document.getElementById('start-content').style.display = 'none';
        document.getElementById('result-content').style.display = 'block';
    }

    function updateTurn(count) { document.getElementById('turn-display').innerText = count; }
    function addLog(q, a, type) {
        const div = document.createElement('div');
        div.className = `log-item ${type}`;
        div.innerHTML = `<span>${q}</span><span style="font-weight:bold">${a}</span>`;
        document.getElementById('logs').prepend(div);
    }
    function getOpText(op) { return op === 'equal' ? 'と同じ' : op === 'gte' ? '以上' : '以下'; }

    // --- 📖 コンプリート図鑑のロジック ---

    // ★ どこから図鑑を開いたか記憶する変数を追加
    let previousScreenForZukan = 'start-content';

    function saveToZukan(id, turns) {
        // localStorage から過去のデータを取得（なければ空のオブジェクト）
        let zukan = JSON.parse(localStorage.getItem('chemZukan')) || {};
        
        // 初めての正解、または過去の記録より少ないターン数でクリアした場合に更新
        if (!zukan[id] || turns < zukan[id]) {
            zukan[id] = turns;
            localStorage.setItem('chemZukan', JSON.stringify(zukan));
        }
    }

    // ★ 2つのボタンの数字を両方とも更新するように変更
    function updateZukanCount() {
        let zukan = JSON.parse(localStorage.getItem('chemZukan')) || {};
        const count = Object.keys(zukan).length;
        const startEl = document.getElementById('start-zukan-count');
        const resultEl = document.getElementById('result-zukan-count');
        if (startEl) startEl.innerText = count;
        if (resultEl) resultEl.innerText = count;
    }

    // ★ 引数(fromScreen)を受け取って、元の画面を非表示にするように変更
    async function openZukan(fromScreen = 'start-content') {
        previousScreenForZukan = fromScreen; // 開いた画面を記憶
        
        document.getElementById('start-content').style.display = 'none';
        document.getElementById('result-content').style.display = 'none'; // 結果画面も非表示にする
        document.getElementById('zukan-content').style.display = 'block';

        const response = await fetch('/api/compounds/zukan');
        const allCompounds = await response.json();
        let zukan = JSON.parse(localStorage.getItem('chemZukan')) || {};
        
        document.getElementById('zukan-progress').innerText = Object.keys(zukan).length;
        const grid = document.getElementById('zukan-grid');
        grid.innerHTML = '';

        allCompounds.forEach(c => {
            const div = document.createElement('div');
            const isUnlocked = zukan.hasOwnProperty(c.id);
            div.className = `zukan-item ${isUnlocked ? '' : 'locked'}`;

            const bestTurns = zukan[c.id];
            let rankHtml = "";
            if (isUnlocked) {
                let rank = bestTurns <= 5 ? "S" : bestTurns <= 8 ? "A" : bestTurns <= 12 ? "B" : "C";
                rankHtml = `<div class="best-rank">Best: ${bestTurns}手 (Rank ${rank})</div>`;
            }

            const displayName = isUnlocked ? c.name : "???";
            const displayFormula = isUnlocked ? c.formula.replace(/(\d+)/g, "<sub>$1</sub>") : "???";
            
            div.innerHTML = `
                <img src="/images/${c.image}" alt="${displayName}">
                <div class="name">${displayName}</div>
                <div class="formula">${displayFormula}</div>
                ${rankHtml}
            `;
            grid.appendChild(div);
        });
    }

    // ★ 記憶しておいた元の画面に戻すように変更
    function closeZukan() {
        document.getElementById('zukan-content').style.display = 'none';
        document.getElementById(previousScreenForZukan).style.display = 'block'; 
        updateZukanCount(); 
    }
</script>
</body>
</html>